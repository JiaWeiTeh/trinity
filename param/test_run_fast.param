# =============================================================================
# Tuple mode: specify exact (dens_profile, densPL_alpha, densBE_Omega) combos
# =============================================================================
# for ultra fast run.
tuple(dens_profile, densPL_alpha, densBE_Omega) [densPL, -1, 0]

# =============================================================================
# Fixed parameters (constant across all runs)
# =============================================================================

# Cloud properties
mCloud    1e5
sfe       0.01
nCore     1e4
rCore     1

# ISM properties
nISM    1
stop_t_diss 1

# Allow expansion beyond cloud
stop_at_rCloud_nSnap    5

# Output directory
path2output    outputs/test_run

# Run settings
stop_r    None
stop_t    1e-3

# Suppress warnings to save memory
log_level    INFO
include_PHII True

# sps stuffs
sps_path  lib/sps/custom/1e6cluster_default.csv
sps_col_t            0 yr linear
sps_col_Qi           1 cgs log
sps_col_fi           2 cgs log
sps_col_Lbol         3 cgs log
sps_col_Lmech_W      6 cgs log
sps_col_pdot_W       5 cgs log
sps_col_Lmech_total  4 cgs log