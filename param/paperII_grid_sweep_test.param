# ==============================================================================
# Sweep Parameter File: Paper II — full GMC / feedback grid
# ==============================================================================
#
# Full Cartesian (grid) sweep over the six axes below. Each `key [list]` is one
# sweep dimension; the runner expands the product of all of them.
#
#   sfe            11 values
#   mCloud         10 values
#   nCore           3 values
#   PISM            4 values
#   nISM            2 values
#   (coverFraction fixed at 1.0 — sealed Weaver bubble, not swept)
#   -----------------------------------------------------------------
#   total          11 x 10 x 3 x 4 x 2 = 2,640 combinations
#
# Usage:
#   python run.py param/paperII_grid_sweep.param --dry-run        # list, run nothing
#   python run.py param/paperII_grid_sweep.param --workers N      # run across N workers
#   python run.py param/paperII_grid_sweep.param --emit-jobs jobs/  # then sbatch for HPC
#

# =============================================================================
# Sweep axes (Cartesian product)
# =============================================================================


# for testing purposes this is very small.
tuple(sfe, mCloud) [0.01, 1e5] [0.9, 5e9]

# Core number density [cm^-3]: decade spacing
nCore           1e4

# ISM pressure P/k [K cm^-3]
PISM            0

# ISM number density [cm^-3]
nISM            1


# =============================================================================
# Fixed parameters (constant across all runs)
# =============================================================================

# Density profile
dens_profile    densPL
densPL_alpha    0

# Cloud
ZCloud    1

# Covering (closed) fraction — 1.0 = sealed (Weaver) bubble, no venting
coverFraction    1.0

# Max plausible cloud radius for the pre-run GMC validation [pc] (default 200).
# Raised to 300 to allow more diffuse clouds.
rCloud_max    300

# Termination
allowShellDissolution    True
stop_t_diss    1
stop_r    None
stop_t    3
coll_r    1
stop_at_rCloud_nSnap    None

# Logging
log_level    INFO

# P_HII
include_PHII    True

# Output (each run writes a subfolder under this directory)
path2output    outputs/paperII_grid_sweep_test

# SPS: use the bundled default Starburst99 table (sps_path left unset).
# The previous explicit block pointed at lib/sps/custom/1e6cluster_default.csv,
# which is gitignored (won't reach the cluster). The bundled default file is
# byte-identical to it, so this changes nothing physically.
