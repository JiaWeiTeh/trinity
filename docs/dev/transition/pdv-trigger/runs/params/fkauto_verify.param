# Live verification of cooling_boost_kappa=auto (pt3).
# Same recipe as one cell of the 819-run sweep (sweep_fkappa_nH.param):
# (mCloud 1e5, sfe 0.03, nCore 1e3) — a Lancaster-like 1e5 Msun GMC. The sweep
# measured f_kappa_fire = 12 here (fkappa_nH_sweep.csv), so 'auto' must resolve
# to 12.0 and the run must leave the energy phase via cooling_balance
# (theta = Lloss/Lgain > 0.95) and reach the momentum phase before stop_t.
# Reduce with: python docs/dev/transition/pdv-trigger/data/make_fkappa_auto_verify.py
model_name             fkauto_verify
mCloud                 1e5
sfe                    0.03
nCore                  1e3
dens_profile           densPL
densPL_alpha           0
nISM                   0.1
stop_t                 2.0
cooling_boost_kappa    auto
log_console            False
log_file               True
path2output            outputs/fkauto_verify
